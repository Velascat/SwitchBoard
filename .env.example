# SwitchBoard environment configuration
# Copy this file to .env and fill in your values.

# ── Service binding ─────────────────────────────────────────────────────────
SWITCHBOARD_HOST=0.0.0.0
SWITCHBOARD_PORT=20401

# ── Observability ────────────────────────────────────────────────────────────
# Log level: debug, info, warning, error, critical
SWITCHBOARD_LOG_LEVEL=INFO

# ── Configuration file paths ─────────────────────────────────────────────────
SWITCHBOARD_POLICY_PATH=./config/policy.yaml

# ── Decision log ─────────────────────────────────────────────────────────────
# Path to write the decision JSONL log (directory is created automatically).
# Leave blank to disable.
SWITCHBOARD_DECISION_LOG_PATH=./runtime/decisions.jsonl
