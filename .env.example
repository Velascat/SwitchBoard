# SwitchBoard environment configuration
# Copy this file to .env and fill in your values.

# URL of the downstream 9router instance
NINE_ROUTER_URL=http://localhost:20128

# Port SwitchBoard listens on
SWITCHBOARD_PORT=20401

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Path to the policy rules file (relative to project root or absolute)
POLICY_PATH=config/policy.yaml

# Path to the model profiles file
PROFILES_PATH=config/profiles.yaml

# Path to the capability registry file
CAPABILITIES_PATH=config/capabilities.yaml

# Path to write the decision JSONL log (leave blank to disable)
DECISION_LOG_PATH=decisions.jsonl
